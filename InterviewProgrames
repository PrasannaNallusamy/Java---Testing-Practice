	public static void main(String[] args) {

		String sentence = "My name is prakash. My country is India. India is a big country";

		String[] input = sentence.split(" ");

		Map<String, Integer> mp = new HashMap();

		for (int i = 0; i < input.length; i++) {
			String key = input[i];
			if (mp.containsKey(key)) {
				Integer n = mp.get(key);
				mp.put(key, n + 1);
			} else {
				mp.put(key, 1);
			}
		}

		System.out.println(mp);

		// Variables to track the most frequent word and its count
		String maxWord = "";
		int maxCount = 0;

		// Find the word with the highest count
		for (Map.Entry<String, Integer> entry : mp.entrySet()) {
			if (entry.getValue() > maxCount) {
				maxCount = entry.getValue();
				maxWord = entry.getKey();
			}

		}
		System.out.println("The most frequent word is: " + maxWord);

	}

