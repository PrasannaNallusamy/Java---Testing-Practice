// first non repeating characters
	public static void main(String[] args) {

		String s = "Happy Hollidays";

		s = s.toLowerCase().replace(" ", "");
		Map<Character, Integer> mp = new LinkedHashMap();

		for (int i = 0; i < s.length(); i++) {
			char c = s.charAt(i);

			if (mp.containsKey(c)) {
				Integer n = mp.get(c);

				mp.put(c, n + 1);

			} else {
				mp.put(c, 1);
			}

		}
	//first non repeating code getValue() == 1 ,first repeating code getValue() == 1
	
		Set<Map.Entry<Character, Integer>> mpentry = mp.entrySet();
		for (Map.Entry<Character, Integer> charecters : mpentry) {
			if (charecters.getValue() == 1) {
				System.out.println("First Non repeating character : " + charecters.getKey());
				break;
			}
		}
	}	

