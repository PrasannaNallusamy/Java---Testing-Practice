//// Reverse and palindrome 	
	public static void main(String[] args) {
		
		int a = 886688, b = 0, c = 0, d = a;
		while (a > 0) {
			b = a % 10;
			c = (c * 10) + b;
			a = a / 10;
		}
		System.out.println("Rversed Number :" + c);

		if (d == c) {

			System.out.println("Number is palindrom");
		}
	}

Output:
	Rversed Number :886688
	Number is palindrom
