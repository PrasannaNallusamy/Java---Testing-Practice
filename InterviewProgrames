// java code to print array elements appearing 2 or more times
	public static void main(String[] args) {

		String[] s = { "r", "y", "u", "r", "y" };

		Map<String, Integer> mp = new LinkedHashMap();

		for (int i = 0; i < s.length; i++) {
			String s1 = s[i];
			if (mp.containsKey(s1)) {
				Integer n = mp.get(s1);
				mp.put(s1, n + 1);
			} else {

				mp.put(s1, 1);
			}
		}
		Set<Map.Entry<String, Integer>> entry = mp.entrySet();
		for (Map.Entry<String, Integer> values : entry) {
			if (values.getValue() <= 2) {

				System.out.println(values.getKey());
			}
		}
	}
	
Output:
	r
	y
	u

